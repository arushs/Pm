# ----- Database -----
# Local dev uses SQLite (zero setup). Keep this default, then run:
#   npm run db:push && npm run db:seed
DATABASE_URL="file:./dev.db"
#
# Production (Postgres / Neon / Supabase): set the datasource provider in
# prisma/schema.prisma to "postgresql" and use a connection string like:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ----- Auth -----
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-to-something-32-chars-or-more"

# Public base URL, used in magic links and notification emails.
APP_URL="http://localhost:3000"

# ----- Email (optional) -----
# If RESEND_API_KEY is empty, magic links sign you in directly in dev and
# notification emails are printed to the server console instead of sent.
RESEND_API_KEY=""
EMAIL_FROM="Hunch <onboarding@resend.dev>"

# ----- Governance -----
# Number of approvals required to open a proposed market.
# If unset, defaults to a majority of all members: floor(members / 2) + 1 (min 2).
# APPROVAL_QUORUM="10"

# Seeded admin (can resolve markets and manage members).
ADMIN_EMAIL="arushshankar@gmail.com"
